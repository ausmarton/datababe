# Firebase configuration for local development.
# Copy to firebase.env and fill in real values:
#   cp firebase.env.example firebase.env
#
# Then run with:
#   flutter run -d chrome --dart-define-from-file=firebase.env

WEB_API_KEY=your-web-api-key
WEB_APP_ID=your-web-app-id
ANDROID_API_KEY=your-android-api-key
ANDROID_APP_ID=your-android-app-id
MESSAGING_SENDER_ID=your-sender-id
FIREBASE_PROJECT_ID=your-project-id
AUTH_DOMAIN=your-project.firebaseapp.com
STORAGE_BUCKET=your-project.firebasestorage.app
MEASUREMENT_ID=G-XXXXXXXXXX
